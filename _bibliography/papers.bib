@article{churning_2026,
  title={The Volatility Advantages of Large Labor Markets},
  author={Conte, Maddalena and Mejean, Isabelle and Michalski, Tomasz and Schmutz, Benoit},
  year={2026},
  abstract={Firms' labor demand is more volatile in larger cities. We propose and test a novel explanation for this finding. Faster hiring conditions attract productive firms with more volatile activity to denser locations where they can swiftly downsize or expand. We estimate a model of firm location choice using French data and show that (i) firm volatility is half as predictive of location choice as productivity; (ii) both dimensions reinforce each other. This mechanism reduces the productivity--density gradient among volatile firms. Imperfectly correlated firm-level shocks, combined with higher operating costs induced by density, generate matching economies.},
  html={https://drive.google.com/file/d/1No_KjR083OYdYtFJd6Zr9KMNLvE_8uLK/view?usp=drive_link},  
  note={Conditionally accepted, Journal of the European Economic Association },
  number = {18925}
}

@article{netmig_2026,
  title={Moving to opportunity? Networks and skill-biased migration},
  author={Conte, Maddalena},
  year={2026},
  abstract={Despite large spatial disparities in economic opportunity, many workers, particularly the low-skilled, remain in low-opportunity regions. I show that the geographic structure of professional networks is an important determinant of this limited mobility. I exploit quasi-exogenous variation in workers’ exposure to migration opportunities arising from the location of their former coworkers. Using matched employer–employee data from France, I find that greater exposure to regional mobility opportunities provided by the network increases cross-city job transitions. These effects are substantially stronger for high-skilled workers, especially for moves toward high-opportunity cities. In contrast, low-skilled workers, whose networks are more geographically concentrated, respond less to such exposure. As a result, professional networks amplify spatial inequalities by mostly facilitating the relocation of high-skilled workers to high-opportunity areas.},
  html={https://drive.google.com/file/d/1ckfmVns12mgKQM-rC20MnHLVWG2EW3ul/view?usp=sharing},  
}

@article{public_housing_2026,
  title={Affordable housing and the labor market: evidence from the city of Copenhagen},
  author={Conte, Maddalena and Mulalic, Ismir and {van Ommeren}, Jos},
  year={2026},
  abstract={This paper investigates the impact of affordable housing policies on long-run labor market outcomes in a quasi-natural experimental setting for Copenhagen. We compare two key affordable housing policies - home purchase subsidies and public rental housing - both directed towards low-income households. We find that subsidized home-buying has a negative effect on labor market participation, compared to subsidized rental, as home-buyers experience large wealth increases, which reduce work incentives. Comparing children of home-buyers and renters in public housing, we find limited effects on their adult labor market participation. However, we show that public housing privatisation can in the long run increase housing inequalities, due to the high inter-generational persistence of home-ownership.},
  note={(New draft coming soon)},
}

